# Quip V2 — local environment
# Copy this file to `.env` and fill in your API keys.
#
# V2 model routing: Groq is PRIMARY (fast + free tier), OpenRouter is FALLBACK.
# If Groq fails (auth, rate limit, network), Quip auto-falls to OpenRouter.
# At least one key must be set for chat to work. Task execution is local and
# works without any keys.
#
# Get a free Groq key at:       https://console.groq.com/keys
# Get a free OpenRouter key at: https://openrouter.ai/keys

GROQ_API_KEY=
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: override the fallback chat model (OpenRouter)
# OPENROUTER_MODEL=google/gemma-3-27b-it:free
